# pdf-backup configuration
# Edit these values before running pdf-backup.sh

SOURCE=/mnt/raid0/monolithic_pdf_folder
DEST=/mnt/pdf_backup

# Exclude individual PDFs larger than this (adjust based on size distribution)
# 50M is a reasonable starting heuristic — bump up/down to tune total transfer size
MAX_FILE_SIZE=10M

# Where rsync progress/stats are logged
LOG_FILE=/var/log/pdf-backup/rsync.log

# PID file — used by stop.sh to find and kill the running rsync
PID_FILE=/var/run/pdf-backup.pid

# Extra rsync flags (add --checksum here if you want byte-for-byte verification;
# warning: --checksum is very slow on 2.4M files)
RSYNC_EXTRA_FLAGS=""
